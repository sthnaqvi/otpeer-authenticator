# IDE files
.vscode/*
.DS_Store

# AI assistant workspaces
.claude/
.cursor/

# Logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules
jspm_packages

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Yarn package manager
yarn.lock


# local_data
local_data
local_data/*

# vault backups accidentally exported into the repo (real secrets!)
authenticator-backup.*

# TypeScript build output
packages/*/dist

# Vendored copy of @authenticator/core inlined into the published CLI package
packages/cli/vendor